# Supabase (required for trip persistence & auth)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Gemini AI (optional — app uses rich mock data when missing)
GEMINI_API_KEY=your-gemini-api-key

# Set to true to skip AI calls and use pre-built Indian destination data
DEMO_MODE=true

# Setup steps:
# 1. Create a Supabase project at https://supabase.com
# 2. Run schema.sql in the SQL Editor
# 3. Copy this file to .env.local and fill in your keys
# 4. Enable Email auth in Supabase → Authentication → Providers
